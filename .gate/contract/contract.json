{
  "root_contract": {
    "allow_dot_folders_only": false,
    "required_root_files": [
      ".gitignore",
      "README.md",
      "composer.json"
    ],
    "allowed_root_files_exact": [
      ".gitignore",
      "README.md",
      "composer.json"
    ],
    "allowed_root_dirs_exact": [
      "bin",
      "build",
      "config",
      "delivery",
      "deploy",
      "docs",
      "drivers",
      "migrations",
      "ops",
      "public",
      "src"
    ],
    "root_directory_policy": "allow listed application/tooling directories and listed dot-folders only"
  },
  "gitignore_template": {
    "must_include_all": [
      ".idea/",
      "*.iml",
      "/vendor/",
      "/var/",
      ".phpunit.result.cache",
      ".DS_Store",
      "Thumbs.db",
      "node_modules/",
      "/.env.local",
      "/.env.*.local"
    ]
  },
  "allowed_root_dot_folders": [
    ".canonization",
    ".commanding",
    ".consuming",
    ".gate",
    ".github",
    ".ide",
    ".intelligence"
  ]
}
