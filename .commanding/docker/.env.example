# Docker env (example). Copy to .env and adjust.
# This file is the single source of truth for:
# - docker compose interpolation (ports/users/passwords)
# - Symfony runtime env inside the php container (via env_file)

APP_ENV=dev
APP_DEBUG=1
WORKSPACE_TIMEZONE=America/Chicago

# Web (nginx)
NGINX_HTTP_PORT=8080
NGINX_HTTPS_PORT=8443

# PHP-FPM (optional host port mapping)
PHP_VERSION=8.4
PHP_PORT=9000

# Postgres
POSTGRES_PORT=5432
POSTGRES_DB=app
POSTGRES_USER=app
POSTGRES_PASSWORD=app

# Redis
REDIS_PORT=6379
REDIS_QUEUE_PORT=6380

# Elasticsearch
ELASTICSEARCH_PORT=9200

# Symfony / Doctrine (container-to-container)
DATABASE_URL=pgsql://app:app@postgres:5432/app?serverVersion=16&charset=utf8
REDIS_URL=redis://redis:6379
REDIS_QUEUE_URL=redis://redis-queue:6379
ELASTICSEARCH_URL=http://elasticsearch:9200

# Optional
MAILER_DSN=null://null
