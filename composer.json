{
  "name": "marketing-america-corp/vendoring",
  "description": "Vendoring component",
  "type": "project",
  "license": "proprietary",
  "require": {
    "php": "^8.2 || ^8.3 || ^8.4",
    "ext-json": "*"
  },
  "require-dev": {
    "friendsofphp/php-cs-fixer": "^3.66"
  },
  "autoload": {
    "psr-4": {
      "App\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "App\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "cs:fix": [
      "php vendor/bin/php-cs-fixer fix --config=.php-cs-fixer.php --allow-risky=yes"
    ],
    "cs:check": [
      "php vendor/bin/php-cs-fixer fix --config=.php-cs-fixer.php --dry-run --diff --allow-risky=yes"
    ]
  },
  "config": {
    "sort-packages": true,
    "allow-plugins": {
      "php-http/discovery": true
    }
  }
}
