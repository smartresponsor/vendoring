            "php tests/bin/transaction-error-surface-smoke.php",
            "php vendor/bin/phpunit --configuration phpunit.xml.dist --testsuite vendoring --filter VendorTransactionControllerTest",
            "php vendor/bin/phpunit --configuration phpunit.xml.dist --testsuite unit --filter VendorTransactionManagerTest",
            "php vendor/bin/phpunit --configuration phpunit.xml.dist --testsuite unit --filter VendorTransactionAmountPolicyTest"
        ],
        "test:transaction-status-persistence": [
            "php tests/bin/transaction-status-persistence-smoke.php",
            "php vendor/bin/phpunit --configuration phpunit.xml.dist --testsuite unit --filter VendorTransactionStatusPolicyTest",
            "php vendor/bin/phpunit --configuration phpunit.xml.dist --testsuite unit --filter TransactionMigrationContractTest"
        ],
        "test:transaction-mapping": [
            "php tests/bin/transaction-mapping-parity-smoke.php",
            "php vendor/bin/phpunit --configuration phpunit.xml.dist --testsuite unit --filter VendorTransactionMappingParityTest"
        ],
        "test:transaction-schema-parity": [
            "php tests/bin/transaction-schema-parity-smoke.php",
            "php vendor/bin/phpunit --configuration phpunit.xml.dist --testsuite unit --filter VendorTransactionSchemaParityTest"
        ],
        "test:transaction-uniqueness-contract": [
            "php tests/bin/transaction-uniqueness-contract-smoke.php",
            "php vendor/bin/phpunit --configuration phpunit.xml.dist --testsuite unit --filter VendorTransactionUniquenessContractTest"
        ],
        "test:transaction-json": [
            "php tests/bin/transaction-json-surface-smoke.php",
            "php vendor/bin/phpunit --configuration phpunit.xml.dist --testsuite vendoring --filter VendorTransactionControllerTest"
        ],
        "test:root-structure": [
            "php tests/bin/root-structure-smoke.php",
            "php vendor/bin/phpunit --configuration phpunit.xml.dist --testsuite unit --filter CanonicalRootStructureContractTest"
        ],
        "test:root-protocol-cleanup": [
            "php tests/bin/root-structure-smoke.php",
            "php vendor/bin/phpunit --configuration phpunit.xml.dist --testsuite unit --filter CanonicalRootStructureContractTest"
