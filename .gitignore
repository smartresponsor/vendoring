# Composer / PHP dependencies
/vendor/
composer.phar

# Symfony runtime state
/var/
/var/cache/
/var/log/
/var/logs/
/var/sessions/
/var/bootstrap.php.cache
/.web-server-pid

# PHPUnit / QA runtime state
/.phpunit.cache/
.phpunit.result.cache
/.php-cs-fixer.cache
/phpstan-report*.txt
/var/phpstan/
/var/*-report.txt

# Node / frontend runtime state
/node_modules/
/npm-debug.log*
/yarn-debug.log*
/yarn-error.log*

# IDE and local workstation files
/.idea/
*.iws
.vscode/

# Build / temporary output
/build/
/report/
/mnt/
/.automation/.tmp/
/.automation/.cache/
*.zip

# Local environment and secrets
.env.local
.env.*.local
/app/config/parameters.yml
/app/config/parameters.ini

# Keep active application directories trackable.
!/public/
!/tools/
!/bin/
!/bin/console
