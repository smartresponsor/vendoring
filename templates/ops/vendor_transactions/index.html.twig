<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Vendor transaction operator surface</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 mb-1">Vendor transaction operator surface</h1>
            <p class="text-muted mb-0">Minimal Twig/Form runtime slice for vendor <strong>{{ vendorId }}</strong>.</p>
        </div>
        <a class="btn btn-outline-secondary" href="{{ path('app_controller_ops_vendortransactionoperatorcontroller_index', {vendorId: vendorId}) }}">Refresh</a>
    </div>

    {% if flashMessage is not null %}
        <div class="alert alert-success" role="alert">{{ flashMessage }}</div>
    {% endif %}

    {% if errorMessage is not null %}
        <div class="alert alert-danger" role="alert">{{ errorMessage }}</div>
    {% endif %}

    <div class="card shadow-sm mb-4">
        <div class="card-header">Create transaction</div>
        <div class="card-body">
            {{ form_start(createForm, {attr: {class: 'row g-3'}}) }}
            <div class="col-md-3">{{ form_row(createForm.vendorId) }}</div>
            <div class="col-md-3">{{ form_row(createForm.orderId) }}</div>
            <div class="col-md-2">{{ form_row(createForm.projectId) }}</div>
            <div class="col-md-2">{{ form_row(createForm.amount) }}</div>
            <div class="col-md-2 d-grid align-self-end">
                <button type="submit" class="btn btn-primary">Create</button>
            </div>
            {{ form_end(createForm) }}
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="card-header">Transactions</div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-striped align-middle mb-0">
                    <thead>
                    <tr>
                        <th>ID</th>
                        <th>Order</th>
                        <th>Project</th>
                        <th>Amount</th>
                        <th>Status</th>
                        <th class="w-25">Operator action</th>
                    </tr>
                    </thead>
                    <tbody>
                    {% for transaction in transactions %}
                        <tr>
                            <td>{{ transaction.id }}</td>
                            <td>{{ transaction.orderId }}</td>
                            <td>{{ transaction.projectId ?? '—' }}</td>
                            <td>{{ transaction.amount }}</td>
                            <td>{{ transaction.status }}</td>
                            <td>
                                {{ form_start(statusForms[transaction.id], {attr: {class: 'row g-2 align-items-center'}}) }}
                                <div class="col-md-8">{{ form_widget(statusForms[transaction.id].status) }}</div>
                                <div class="col-md-4"><button type="submit" class="btn btn-sm btn-outline-primary w-100">Update</button></div>
                                {{ form_end(statusForms[transaction.id]) }}
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="6" class="text-center text-muted">No transactions found for this vendor yet.</td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
</body>
</html>
