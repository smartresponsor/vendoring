{% extends 'base.html.twig' %}
{% import '_macros/crud.html.twig' as crud %}

{% block title %}Vendor transaction operator surface{% endblock %}

{% block shell_eyebrow %}Vendor operations{% endblock %}
{% block shell_title %}Vendor transaction operator surface{% endblock %}
{% block shell_subtitle %}Operator page for vendor {{ vendorId }}{% endblock %}

{% block shell_note %}Minimal Twig/Form runtime slice for vendor <strong>{{ vendorId }}</strong>. The operator surface uses the same shell contract as the rest of the workspace, so the page structure stays consistent even when the inner form changes.{% endblock %}

{% block shell_actions %}
    <a class="crud-app-button" href="{{ path('app_ops_vendor_transaction_operator_index', {vendorId: vendorId}) }}">Refresh</a>
{% endblock %}

{% block body %}
    {% form_theme createForm 'form_div_layout.html.twig' %}
    <div class="crud-app-surface-grid">
        {% if flashMessage is not null %}
            <section class="crud-app-surface">
                <h2 class="crud-app-surface-title">Status</h2>
                {{ crud.alert('is-success', '', flashMessage) }}
            </section>
        {% endif %}

        <section class="crud-app-surface">
            <h2 class="crud-app-surface-title">Create transaction</h2>
            {% if errorMessage is not null %}
                {{ crud.alert('is-danger', 'Operator error', errorMessage) }}
            {% endif %}

            <div class="crud-app-surface">
                {{ form_start(createForm, {attr: {class: 'crud-app-form'}}) }}
                <div class="crud-app-form-grid">
                    <div class="crud-app-field">
                        <label for="vendorIdDisplay" class="crud-app-field-label">Vendor ID</label>
                        <input id="vendorIdDisplay" class="crud-app-input" value="{{ vendorId }}" readonly disabled>
                    </div>
                    {{ crud.field(createForm.orderId) }}
                    {{ crud.field(createForm.projectId) }}
                    {{ crud.field(createForm.amount) }}
                </div>
                <div class="crud-app-form-actions">
                    <button type="submit" class="crud-app-button is-primary">Create</button>
                </div>
                {{ form_end(createForm) }}
            </div>
        </section>

        <section class="crud-app-surface" style="grid-column: 1 / -1;">
            <h2 class="crud-app-surface-title">Transactions</h2>
            <div class="crud-app-table-wrap">
                <table class="crud-app-table">
                    <thead>
                    <tr>
                        <th>ID</th>
                        <th>Order</th>
                        <th>Project</th>
                        <th>Amount</th>
                        <th>Status</th>
                        <th class="w-25">Operator action</th>
                    </tr>
                    </thead>
                    <tbody>
                    {% for transaction in transactions %}
                        <tr>
                            <td>{{ transaction.id }}</td>
                            <td>{{ transaction.orderId }}</td>
                            <td>{{ transaction.projectId ?? '—' }}</td>
                            <td>{{ transaction.amount }}</td>
                            <td>{{ statusLabels[transaction.status] ?? transaction.status }}</td>
                            <td>
                                {% form_theme statusForms[transaction.id] 'form_div_layout.html.twig' %}
                                {{ form_start(statusForms[transaction.id], {attr: {class: 'crud-app-form'}}) }}
                                <div class="crud-app-form-grid" style="grid-template-columns: minmax(0, 1fr) auto; align-items: end;">
                                    {{ crud.field(statusForms[transaction.id].status, 'crud-app-select') }}
                                    <div class="crud-app-form-actions">
                                        <button type="submit" class="crud-app-button">Update</button>
                                    </div>
                                </div>
                                {{ form_end(statusForms[transaction.id]) }}
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="6" style="text-align: center; color: var(--crud-shell-muted);">No transactions found for this vendor yet.</td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
        </section>
    </div>
{% endblock %}
