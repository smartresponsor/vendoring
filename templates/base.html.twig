<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{% block title %}Vendoring{% endblock %}</title>
  </head>
  <body>
    {% set shellCrud = crud|default(null) %}
    {% set shellPage = page|default(null) %}
    {% set shellResourcePath = shellCrud.resourcePath|default('catalog') %}
    {% set shellOperation = shellCrud.operation|default('index') %}
    {% set shellPageTitle = shellPage.title|default(shellResourcePath|title) %}
    {% set shellSearchQuery = app.request.query.get('q')|default('') %}
    {% set shellObjects = shellPage.objects|default([]) %}
    {% set shellActions = shellPage.actions|default([]) %}
    {% set shellMenuLinks = [
      {'label': 'Catalog', 'href': '/catalog/'},
      {'label': 'Vendor', 'href': '/vendor/'},
      {'label': 'Order', 'href': '/order/'},
      {'label': 'Billing', 'href': '/billing/'},
      {'label': 'Shipping', 'href': '/shipping/'},
      {'label': 'Tagging', 'href': '/tag/'}
    ] %}
    {% set shellResourceLinks = [
      {'label': 'Index', 'href': '/' ~ shellResourcePath ~ '/'},
      {'label': 'New', 'href': '/' ~ shellResourcePath ~ '/new/'},
      {'label': 'Show sample', 'href': '/' ~ shellResourcePath ~ '/sample'},
      {'label': 'Edit sample', 'href': '/' ~ shellResourcePath ~ '/edit/sample'},
      {'label': 'Delete sample', 'href': '/' ~ shellResourcePath ~ '/delete/sample'}
    ] %}
    {% set shellQuickMenuGroup = [
      {'title': 'My account', 'link': [
        {'label': 'Profile', 'href': '/vendor/'},
        {'label': 'Security', 'href': '/security/'},
        {'label': 'Notifications', 'href': '/notification/'},
        {'label': 'Addresses', 'href': '/address/'}
      ]},
      {'title': 'My commerce', 'link': [
        {'label': 'Cart', 'href': '/cart/'},
        {'label': 'Orders', 'href': '/order/'},
        {'label': 'Payments', 'href': '/payment/'},
        {'label': 'Subscription', 'href': '/subscription/'}
      ]},
      {'title': 'System shortcuts', 'link': [
        {'label': 'Catalog', 'href': '/catalog/'},
        {'label': 'Currency', 'href': '/currency/'},
        {'label': 'Exchange rates', 'href': '/exchange-rate/'},
        {'label': 'Commission plans', 'href': '/commission-plan/'}
      ]}
    ] %}
    {% set shellFooterGroup = [
      {'title': 'Commerce core', 'link': [
        {'label': 'Catalog', 'href': '/catalog/'},
        {'label': 'Search', 'href': '/search/'},
        {'label': 'Cart', 'href': '/cart/'},
        {'label': 'Orders', 'href': '/order/'},
        {'label': 'Payments', 'href': '/payment/'},
        {'label': 'Shipping', 'href': '/shipping/'},
        {'label': 'Taxation', 'href': '/taxation/'}
      ]},
      {'title': 'Commerce finance', 'link': [
        {'label': 'Currencies', 'href': '/currency/'},
        {'label': 'Money formats', 'href': '/money-format/'},
        {'label': 'Exchange rates', 'href': '/exchange-rate/'},
        {'label': 'Exchange quotes', 'href': '/exchange-quote/'},
        {'label': 'Subscriptions', 'href': '/subscription/'},
        {'label': 'Plans', 'href': '/subscription-plan/'},
        {'label': 'Commissions', 'href': '/commission-plan/'}
      ]},
      {'title': 'Customer account', 'link': [
        {'label': 'Vendor index', 'href': '/vendor/'},
        {'label': 'Security', 'href': '/security/'},
        {'label': 'Notifications', 'href': '/notification/'},
        {'label': 'My subscription', 'href': '/subscription/'},
        {'label': 'Order history', 'href': '/order/'}
      ]},
      {'title': 'Application indexes', 'link': [
        {'label': 'Vendor', 'href': '/vendor/'},
        {'label': 'Billing', 'href': '/billing/'},
        {'label': 'Tagging', 'href': '/tag/'},
        {'label': 'Commissioning', 'href': '/commission-plan/'},
        {'label': 'Currencing', 'href': '/currency/'}
      ]},
      {'title': 'System links', 'link': [
        {'label': 'Locale selector', 'href': '/locale/'},
        {'label': 'Applications', 'href': '/application/'},
        {'label': 'Components', 'href': '/component/'},
        {'label': 'CRUD explorer', 'href': '/interfacing/crud/explorer'},
        {'label': 'Screen catalog', 'href': '/interfacing/screens'}
      ]},
      {'title': 'Support & policy', 'link': [
        {'label': 'Help center', 'href': '/support/'},
        {'label': 'Returns', 'href': '/return/'},
        {'label': 'Privacy', 'href': '/privacy/'},
        {'label': 'Terms', 'href': '/terms/'}
      ]}
    ] %}
    {% set shellSecondaryLinks = [
      {'label': 'Path: ' ~ shellResourcePath, 'value': shellResourcePath},
      {'label': 'Operation', 'value': shellOperation},
      {'label': 'Surface', 'value': shellCrud.surface|default('public')},
      {'label': 'Objects', 'value': shellObjects|length}
    ] %}
    {% set shellRightLinks = shellActions %}
    <style>
      :root {
        --crud-shell-bg: #f4f7fb;
        --crud-shell-panel: #ffffff;
        --crud-shell-border: #d7e0ea;
        --crud-shell-border-soft: #e9eef4;
        --crud-shell-text: #182230;
        --crud-shell-muted: #5b6574;
        --crud-shell-accent: #1d4ed8;
        --crud-shell-radius: 12px;
        --crud-shell-shadow: 0 10px 24px rgba(15, 23, 42, 0.06);
      }
      * { box-sizing: border-box; }
      body {
        margin: 0;
        color: var(--crud-shell-text);
        background: var(--crud-shell-bg);
        font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      }
      a { color: var(--crud-shell-accent); }
      .crud-app-shell {
        min-height: 100vh;
        display: grid;
        grid-template-rows: auto 1fr auto;
      }
      .crud-app-top {
        position: sticky;
        top: 0;
        z-index: 20;
        background: rgba(255, 255, 255, 0.98);
        backdrop-filter: blur(10px);
        border-bottom: 1px solid var(--crud-shell-border);
      }
      .crud-app-top-inner,
      .crud-app-footer-inner {
        max-width: 1720px;
        margin: 0 auto;
        padding: 8px 12px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
      }
      .crud-app-brand {
        display: flex;
        text-decoration: none;
        color: var(--crud-shell-text);
        min-width: 0;
        align-items: center;
      }
      .crud-app-brand strong {
        font-size: 13px;
        line-height: 1.1;
      }
      .crud-app-brand span {
        font-size: 10px;
        color: var(--crud-shell-muted);
      }
      .crud-app-brand-mark {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 28px;
        height: 28px;
        border-radius: 10px;
        background: var(--crud-shell-accent);
        color: #fff;
        font-size: 12px;
        font-weight: 800;
        margin-right: 8px;
        flex: 0 0 auto;
      }
      .crud-app-brand-row {
        display: flex;
        align-items: center;
      }
      .crud-app-brand-copy {
        display: flex;
        flex-direction: column;
      }
      .crud-app-top-meta,
      .crud-app-actions,
      .crud-app-inline-links,
      .crud-app-footer-links {
        display: flex;
        flex-wrap: wrap;
        gap: 6px;
      }
      .crud-app-search {
        display: flex;
        align-items: center;
        gap: 6px;
        min-width: 220px;
        flex: 0 1 320px;
        max-width: 420px;
      }
      .crud-app-search input {
        width: 100%;
        border: 1px solid var(--crud-shell-border);
        border-radius: 999px;
        padding: 8px 12px;
        font: inherit;
        color: var(--crud-shell-text);
        background: #fff;
      }
      .crud-app-pill,
      .crud-app-button {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 6px;
        text-decoration: none;
        border-radius: 999px;
        border: 1px solid var(--crud-shell-border);
        background: #fff;
        color: var(--crud-shell-text);
        padding: 6px 10px;
        font-size: 12px;
        font-weight: 600;
      }
      .crud-app-pill.is-primary {
        background: var(--crud-shell-accent);
        border-color: var(--crud-shell-accent);
        color: #fff;
      }
      .crud-app-button.is-primary {
        background: var(--crud-shell-accent);
        border-color: var(--crud-shell-accent);
        color: #fff;
      }
      .crud-app-main {
        max-width: 1720px;
        width: 100%;
        margin: 0 auto;
        padding: 12px;
      }
      .crud-app-grid {
        display: grid;
        grid-template-columns: 220px 220px minmax(0, 1fr) 240px;
        gap: 8px;
        min-height: calc(100vh - 110px);
      }
      .crud-app-panel {
        background: rgba(255, 255, 255, 0.96);
        border: 1px solid var(--crud-shell-border);
        box-shadow: var(--crud-shell-shadow);
      }
      .crud-app-left,
      .crud-app-right {
        padding: 10px;
        overflow: auto;
      }
      .crud-app-left {
        border-radius: var(--crud-shell-radius);
      }
      .crud-app-right {
        border-radius: var(--crud-shell-radius);
      }
      .crud-app-center {
        padding: 0;
        min-width: 0;
      }
      .crud-app-section {
        margin-bottom: 10px;
      }
      .crud-app-section-title {
        margin: 0 0 8px;
        font-size: 10px;
        letter-spacing: .06em;
        text-transform: uppercase;
        color: var(--crud-shell-muted);
        font-weight: 800;
      }
      .crud-app-link-list,
      .crud-app-meta-list {
        display: flex;
        flex-direction: column;
        gap: 8px;
      }
      .crud-app-link,
      .crud-app-meta-item {
        display: block;
        text-decoration: none;
        color: var(--crud-shell-text);
        border: 1px solid var(--crud-shell-border-soft);
        border-radius: 10px;
        background: #fff;
        padding: 8px 10px;
      }
      .crud-app-link strong,
      .crud-app-meta-item strong {
        display: block;
        font-size: 12px;
        margin-bottom: 3px;
      }
      .crud-app-link span,
      .crud-app-meta-item span {
        display: block;
        color: var(--crud-shell-muted);
        font-size: 11px;
        line-height: 1.35;
      }
      .crud-app-center-card {
        min-height: 100%;
        padding: 0;
        border-radius: var(--crud-shell-radius);
        background: rgba(255, 255, 255, 0.95);
        border: 1px solid var(--crud-shell-border);
        box-shadow: var(--crud-shell-shadow);
        overflow: hidden;
      }
      .crud-app-center-inner {
        padding: 14px;
      }
      .crud-app-center-shell {
        display: grid;
        gap: 14px;
      }
      .crud-app-pagehead {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 12px;
      }
      .crud-app-pagehead-copy {
        min-width: 0;
      }
      .crud-app-page-eyebrow {
        margin: 0 0 4px;
        font-size: 10px;
        font-weight: 800;
        letter-spacing: .08em;
        text-transform: uppercase;
        color: var(--crud-shell-muted);
      }
      .crud-app-page-title {
        margin: 0;
        font-size: 24px;
        line-height: 1.15;
        color: var(--crud-shell-text);
      }
      .crud-app-page-subtitle {
        margin-top: 6px;
        color: var(--crud-shell-muted);
        font-size: 13px;
        line-height: 1.5;
      }
      .crud-app-page-note {
        color: var(--crud-shell-muted);
        font-size: 11px;
        line-height: 1.5;
      }
      .crud-app-page-actions {
        display: flex;
        flex-wrap: wrap;
        justify-content: flex-end;
        gap: 8px;
      }
      .crud-app-surface-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        gap: 12px;
      }
      .crud-app-surface {
        padding: 12px;
        border: 1px solid var(--crud-shell-border-soft);
        border-radius: 12px;
        background: #fff;
      }
      .crud-app-alert {
        padding: 10px 12px;
        border-radius: 12px;
        border: 1px solid var(--crud-shell-border-soft);
        background: #f8fbff;
        color: var(--crud-shell-text);
        font-size: 12px;
        line-height: 1.45;
      }
      .crud-app-alert.is-success {
        border-color: #bbf7d0;
        background: #f0fdf4;
      }
      .crud-app-alert.is-danger {
        border-color: #fecaca;
        background: #fef2f2;
      }
      .crud-app-form {
        display: grid;
        gap: 12px;
      }
      .crud-app-form-grid {
        display: grid;
        gap: 12px;
        grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
      }
      .crud-app-field {
        display: grid;
        gap: 6px;
      }
      .crud-app-field-label {
        font-size: 11px;
        font-weight: 700;
        color: var(--crud-shell-muted);
      }
      .crud-app-input,
      .crud-app-select {
        width: 100%;
        padding: 9px 11px;
        border: 1px solid var(--crud-shell-border);
        border-radius: 10px;
        background: #fff;
        color: var(--crud-shell-text);
        font: inherit;
      }
      .crud-app-input[readonly],
      .crud-app-input[disabled] {
        background: #f8fafc;
        color: var(--crud-shell-muted);
      }
      .crud-app-input-group {
        display: grid;
        grid-template-columns: auto minmax(0, 1fr);
        align-items: stretch;
        border: 1px solid var(--crud-shell-border);
        border-radius: 10px;
        overflow: hidden;
        background: #fff;
      }
      .crud-app-input-prefix {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 0 10px;
        background: #f8fbff;
        color: var(--crud-shell-muted);
        font-size: 12px;
        border-right: 1px solid var(--crud-shell-border);
      }
      .crud-app-input-group .crud-app-input {
        border: 0;
        border-radius: 0;
      }
      .crud-app-form-actions {
        display: flex;
        justify-content: flex-end;
        gap: 8px;
        flex-wrap: wrap;
      }
      .crud-app-surface-title {
        margin: 0 0 10px;
        font-size: 11px;
        font-weight: 800;
        letter-spacing: .06em;
        text-transform: uppercase;
        color: var(--crud-shell-muted);
      }
      .crud-app-table-wrap {
        overflow: auto;
        border: 1px solid var(--crud-shell-border-soft);
        border-radius: 12px;
        background: #fff;
      }
      .crud-app-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 12px;
      }
      .crud-app-table th,
      .crud-app-table td {
        padding: 10px 12px;
        border-bottom: 1px solid var(--crud-shell-border-soft);
        text-align: left;
        vertical-align: top;
      }
      .crud-app-table thead th {
        position: sticky;
        top: 0;
        z-index: 1;
        background: #f8fbff;
        color: var(--crud-shell-muted);
        font-size: 10px;
        text-transform: uppercase;
        letter-spacing: .06em;
      }
      .crud-app-table tbody tr:last-child td {
        border-bottom: 0;
      }
      .crud-app-center-note {
        padding: 0;
        color: var(--crud-shell-muted);
        font-size: 11px;
      }
      .crud-app-footer {
        border-top: 1px solid var(--crud-shell-border);
        background: rgba(255, 255, 255, 0.96);
      }
      .crud-app-quick-menu {
        position: relative;
        flex: 0 0 auto;
      }
      .crud-app-quick-menu summary {
        list-style: none;
        cursor: pointer;
      }
      .crud-app-quick-menu summary::-webkit-details-marker { display: none; }
      .crud-app-quick-menu-panel {
        position: absolute;
        right: 0;
        top: calc(100% + 8px);
        min-width: 320px;
        max-width: min(92vw, 420px);
        padding: 12px;
        border: 1px solid var(--crud-shell-border);
        border-radius: 14px;
        background: #fff;
        box-shadow: 0 18px 42px rgba(15, 23, 42, 0.18);
        display: grid;
        gap: 12px;
      }
      .crud-app-quick-menu-group strong,
      .crud-app-footer-group strong {
        display: block;
        margin-bottom: 6px;
        color: var(--crud-shell-text);
        font-size: 12px;
      }
      .crud-app-quick-menu-links,
      .crud-app-footer-links {
        display: flex;
        flex-wrap: wrap;
        gap: 7px 10px;
      }
      .crud-app-footer-links {
        display: block;
        list-style: disc;
        margin: 0;
        padding-left: 18px;
      }
      .crud-app-quick-menu-links a,
      .crud-app-footer-links a {
        color: var(--crud-shell-text);
        text-decoration: none;
        font-size: 12px;
      }
      .crud-app-quick-menu-links a {
        border: 1px solid var(--crud-shell-border-soft);
        border-radius: 999px;
        padding: 5px 8px;
        background: #f8fbff;
      }
      .crud-app-footer-inner {
        color: var(--crud-shell-muted);
        font-size: 11px;
        align-items: flex-start;
        display: grid;
        grid-template-columns: minmax(180px, 1fr) repeat(auto-fit, minmax(150px, 1fr));
      }
      .crud-app-footer-brand {
        max-width: 240px;
        line-height: 1.5;
      }
      .crud-app-footer-brand strong {
        display: block;
        color: var(--crud-shell-text);
        font-size: 13px;
      }
      .crud-app-footer-group {
        min-width: 0;
      }
      @media (max-width: 1280px) {
        .crud-app-grid { grid-template-columns: 200px minmax(0, 1fr) 220px; }
        .crud-app-left:nth-child(2) { display: none; }
        .crud-app-right { display: none; }
      }
      @media (max-width: 980px) {
        .crud-app-grid { grid-template-columns: 1fr; }
        .crud-app-left, .crud-app-right { border-radius: var(--crud-shell-radius); }
        .crud-app-center { padding: 0; }
        .crud-app-center-card { border-radius: var(--crud-shell-radius); }
        .crud-app-top-inner,
        .crud-app-footer-inner {
          padding-left: 10px;
          padding-right: 10px;
          flex-direction: column;
          align-items: stretch;
        }
        .crud-app-search {
          max-width: none;
          width: 100%;
        }
      }
    </style>

    <div class="crud-app-shell">
      <header class="crud-app-top">
        <div class="crud-app-top-inner">
          <a class="crud-app-brand" href="/catalog/">
            <span class="crud-app-brand-row">
              <span class="crud-app-brand-mark">C</span>
              <span class="crud-app-brand-copy">
                <strong>Cruding</strong>
                <span>{{ shellPageTitle }}</span>
              </span>
            </span>
          </a>

          <form class="crud-app-search" method="get" action="/{{ shellResourcePath }}/">
            <input type="search" name="q" value="{{ shellSearchQuery }}" placeholder="Search {{ shellResourcePath }}">
          </form>

          <div class="crud-app-top-meta">
            <span class="crud-app-pill">Resource: {{ shellResourcePath }}</span>
            <span class="crud-app-pill">Operation: {{ shellOperation }}</span>
            <details class="crud-app-quick-menu" data-cruding-shell-slot="quick-menu" data-cruding-shell-contract="commerce-shell-wave1">
              <summary class="crud-app-pill is-primary">Menu ▾</summary>
              <div class="crud-app-quick-menu-panel">
                {% for group in shellQuickMenuGroup %}
                  <div class="crud-app-quick-menu-group">
                    <strong>{{ group.title }}</strong>
                    <div class="crud-app-quick-menu-links">
                      {% for link in group.link %}
                        <a href="{{ link.href }}">{{ link.label }}</a>
                      {% endfor %}
                    </div>
                  </div>
                {% endfor %}
              </div>
            </details>
          </div>
        </div>
      </header>

      <main class="crud-app-main">
        <div class="crud-app-grid">
          <aside class="crud-app-panel crud-app-left">
            <section class="crud-app-section">
              <h2 class="crud-app-section-title">Resource operations</h2>
              <div class="crud-app-link-list">
                {% for link in shellResourceLinks %}
                  <a class="crud-app-link" href="{{ link.href }}">
                    <strong>{{ link.label }}</strong>
                    <span>{{ link.href }}</span>
                  </a>
                {% endfor %}
              </div>
            </section>
          </aside>

          <aside class="crud-app-panel crud-app-left">
            <section class="crud-app-section">
              <h2 class="crud-app-section-title">Commerce context</h2>
              <div class="crud-app-meta-list">
                {% for item in shellSecondaryLinks %}
                  <div class="crud-app-meta-item">
                    <strong>{{ item.label }}</strong>
                    <span>{{ item.value }}</span>
                  </div>
                {% endfor %}
              </div>
            </section>
          </aside>

          <section class="crud-app-center-card">
            <div class="crud-app-center-inner">
              <div class="crud-app-center-shell">
                <header class="crud-app-pagehead">
                  <div class="crud-app-pagehead-copy">
                    <p class="crud-app-page-eyebrow">{% block shell_eyebrow %}Commerce shell{% endblock %}</p>
                    <h1 class="crud-app-page-title">{% block shell_title %}{{ shellPageTitle }}{% endblock %}</h1>
                    <div class="crud-app-page-subtitle">{% block shell_subtitle %}{% endblock %}</div>
                  </div>
                  <div class="crud-app-page-actions">{% block shell_actions %}{% endblock %}</div>
                </header>
                <div class="crud-app-page-note">
                  {% block shell_note %}{% endblock %}
                </div>
                <div class="crud-app-center-note">
                  {{ shellResourcePath }} · {{ shellOperation }} · {{ shellObjects|length }} objects
                </div>
              </div>
              {% block body %}{% endblock %}
            </div>
          </section>

          <aside class="crud-app-panel crud-app-right">
            <section class="crud-app-section">
              <h2 class="crud-app-section-title">Commerce actions</h2>
              <div class="crud-app-link-list">
                {% if shellActions is not empty %}
                  {% for action in shellActions %}
                    <a class="crud-app-link{% if action.name == 'new' %} is-primary{% endif %}" href="{{ path(action.routeName, action.routeParameters) }}">
                      <strong>{{ action.label }}</strong>
                      <span>{{ action.routeName }}</span>
                    </a>
                  {% endfor %}
                {% else %}
                  <div class="crud-app-meta-item">
                    <strong>No commerce actions</strong>
                    <span>This resource did not expose additional commerce actions for the current page.</span>
                  </div>
                {% endif %}
              </div>
            </section>
          </aside>
        </div>
      </main>

      <footer class="crud-app-footer" data-cruding-shell-slot="commerce-footer" data-cruding-shell-contract="commerce-shell-wave1">
        <div class="crud-app-footer-inner">
          <div class="crud-app-footer-brand">
            <strong>Commerce workspace</strong>
            <span>Cruding renders resource workbenches while the footer exposes system-wide commerce navigation.</span>
          </div>
          {% for group in shellFooterGroup %}
            <div class="crud-app-footer-group">
              <strong>{{ group.title }}</strong>
              <ul class="crud-app-footer-links">
                {% for link in group.link %}
                  <li>
                    <a href="{{ link.href }}">{{ link.label }}</a>
                  </li>
                {% endfor %}
              </ul>
            </div>
          {% endfor %}
        </div>
      </footer>
    </div>
  </body>
</html>
